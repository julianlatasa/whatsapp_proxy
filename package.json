{
  "name": "whatsapp_proxy",
  "version": "1.0.0",
  "description": "Proxy de WhatsApp sobre Baileys, escrito en TypeScript con EventEmitter tipado y patrones de diseño (Singleton, Repository, Strategy, Observer, Factory, Facade).",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typeorm": "node --import tsx node_modules/typeorm/cli.js -d src/storage/cli-data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "backfill:jid-alt": "npm run build && node scripts/backfill-jid-alt.mjs",
    "db:backup": "node scripts/backup.mjs"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.7",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
