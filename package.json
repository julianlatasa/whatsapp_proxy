{
  "name": "whatsapp_proxy",
  "version": "1.0.0",
  "description": "Proxy de WhatsApp sobre Baileys, escrito en TypeScript con EventEmitter tipado y patrones de diseño (Singleton, Repository, Strategy, Observer, Factory, Facade).",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:push": "drizzle-kit push",
    "backfill:jid-alt": "npm run build && node scripts/backfill-jid-alt.mjs"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
